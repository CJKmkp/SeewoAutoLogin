<UserControl x:Class="SeewoAutoLogin.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf">

    <Grid>
        <!-- 主内容 -->
        <Grid x:Name="MainContent">
            <ikw:SimpleStackPanel Spacing="12" Margin="16">

                <!-- 密码保护设置 -->
                <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <ikw:SimpleStackPanel Spacing="8">
                        <TextBlock Text="安全设置" FontSize="14" FontWeight="SemiBold"/>
                        <CheckBox x:Name="UsePluginPasswordCheckBox" Content="使用密码保护插件设置"
                            Checked="PasswordSetting_Changed" Unchecked="PasswordSetting_Changed"/>
                        <StackPanel x:Name="PluginPasswordPanel" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <PasswordBox x:Name="NewPasswordBox" Password="" Padding="8,6" Width="200"
                                    VerticalAlignment="Center"/>
                                <Button x:Name="SetPasswordBtn" Content="设置密码" Click="SetPassword_Click"
                                    Padding="10,6" Margin="8,0,0,0"/>
                                <Button x:Name="ClearPasswordBtn" Content="清除密码" Click="ClearPassword_Click"
                                    Padding="10,6" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="PasswordStatus" FontSize="11" Margin="0,4,0,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ikw:SimpleStackPanel>
                </Border>

                <!-- 账号列表 -->
                <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <Grid>
                                <TextBlock Text="账号列表" FontSize="14" FontWeight="SemiBold"
                                    VerticalAlignment="Center"/>
                                <Button Content="+ 添加账号" Click="AddAccount_Click" Padding="10,4"
                                    HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                        <ui:ListView x:Name="AccountListBox" SelectionChanged="AccountListBox_SelectionChanged"
                            Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" MaxHeight="300">
                            <ui:ListView.Template>
                                <ControlTemplate TargetType="ui:ListView">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter HorizontalAlignment="Stretch"/>
                                        </ScrollViewer>
                                    </Border>
                                </ControlTemplate>
                            </ui:ListView.Template>
                            <ui:ListView.ItemContainerStyle>
                                <Style TargetType="ui:ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="MinHeight" Value="36"/>
                                </Style>
                            </ui:ListView.ItemContainerStyle>
                            <ui:ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ui:ListView.ItemsPanel>
                        </ui:ListView>
                    </DockPanel>
                </Border>

                <!-- 用户列表轮换 -->
                <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <ikw:SimpleStackPanel Spacing="8">
                        <TextBlock x:Name="RotationTitleText" FontSize="14" FontWeight="SemiBold"/>
                        <CheckBox x:Name="RotationEnabledCheckBox" Checked="RotationSetting_Changed" Unchecked="RotationSetting_Changed"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="RotationGroupSizeLabel" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="RotationGroupSizeComboBox" Width="100" SelectionChanged="RotationGroupSize_Changed">
                                <ComboBoxItem Content="4" Tag="4"/>
                                <ComboBoxItem Content="6" Tag="6"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock x:Name="RotationStatusText" FontSize="11"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    </ikw:SimpleStackPanel>
                </Border>

                <!-- 扫码 Token 实验功能 -->
                <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <ikw:SimpleStackPanel Spacing="8">
                        <TextBlock x:Name="ExperimentalTokenRefreshTitleText" FontSize="14" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ExperimentalTokenRefreshCheckBox" Checked="ExperimentalTokenRefresh_Changed" Unchecked="ExperimentalTokenRefresh_Changed"/>
                        <TextBlock x:Name="ExperimentalTokenRefreshDescriptionText" FontSize="11" TextWrapping="Wrap"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </ikw:SimpleStackPanel>
                </Border>

                <!-- 希沃官方扫码登录 -->
                <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <ikw:SimpleStackPanel Spacing="10">
                        <TextBlock x:Name="QrTitleText" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="QrDescriptionText" FontSize="12" TextWrapping="Wrap"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <Grid x:Name="QrCodePanel" Visibility="Collapsed" HorizontalAlignment="Left">
                            <Border Padding="10" Background="White" CornerRadius="6">
                                <Image x:Name="QrCodeImage" Width="220" Height="220" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="QrStatusText" FontSize="12" TextWrapping="Wrap"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="QrCountdownText" FontSize="11"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="StartQrLoginButton" Click="StartQrLogin_Click" Padding="14,6" Margin="0,0,8,0"/>
                            <Button x:Name="RefreshQrLoginButton" Click="RefreshQrLogin_Click" Padding="14,6" Margin="0,0,8,0" Visibility="Collapsed"/>
                            <Button x:Name="CancelQrLoginButton" Click="CancelQrLogin_Click" Padding="14,6" Visibility="Collapsed"/>
                        </StackPanel>
                    </ikw:SimpleStackPanel>
                </Border>

                <!-- 登录区域 -->
                <Border x:Name="LoginPanel" CornerRadius="8" Padding="16" Visibility="Collapsed"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <ikw:SimpleStackPanel Spacing="10">
                        <TextBlock x:Name="LoginPanelTitle" Text="添加账号" FontSize="14" FontWeight="SemiBold"/>
                        <StackPanel>
                            <TextBlock Text="显示名称" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="DisplayNameBox" Padding="8,6"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="手机号 / 用户名" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBox x:Name="UsernameBox" Padding="8,6"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="密码" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="PasswordBox" Padding="8,6"/>
                        </StackPanel>
                        <TextBlock x:Name="LoginStatus" FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="LoginButton" Content="登录并保存" Click="LoginButton_Click"
                                Padding="14,6" Margin="0,0,8,0"/>
                            <Button Content="取消" Click="CancelLogin_Click" Padding="14,6"/>
                        </StackPanel>
                    </ikw:SimpleStackPanel>
                </Border>

                <!-- 当前用户信息 -->
                <Border x:Name="UserInfoCard" CornerRadius="8" Padding="16" Visibility="Collapsed"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <ikw:SimpleStackPanel Spacing="8">
                        <TextBlock Text="当前用户信息" FontSize="14" FontWeight="SemiBold"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="昵称" Opacity="0.6" Margin="0,0,16,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InfoNickName" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="姓名" Opacity="0.6" Margin="0,0,16,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InfoRealName" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="学校" Opacity="0.6" Margin="0,0,16,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InfoUnitName" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="学科" Opacity="0.6" Margin="0,0,16,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InfoSubjectName" Margin="0,0,0,4"/>
                        </Grid>
                    </ikw:SimpleStackPanel>
                </Border>

            </ikw:SimpleStackPanel>
        </Grid>

        <!-- 密码验证遮罩 -->
        <Border x:Name="LockOverlay" Visibility="Collapsed" Panel.ZIndex="100">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource SolidBackgroundFillColorBase}" Opacity="0.95"/>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Lock}" FontSize="48"
                    HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.6"/>
                <TextBlock Text="需要验证身份" FontSize="18" FontWeight="SemiBold"
                    HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="LockHint" FontSize="13"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <PasswordBox x:Name="UnlockPasswordBox" Padding="8,6" Margin="0,0,0,8"/>
                <Button x:Name="UnlockButton" Content="解锁" Click="Unlock_Click"
                    Padding="16,8" HorizontalAlignment="Center"/>
                <TextBlock x:Name="UnlockStatus" FontSize="12" Foreground="Red"
                    HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
